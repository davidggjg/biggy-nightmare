; Engine configuration file.
; Godot 4.x — BIGGY NIGHTMARE

[application]

config/name="Biggy Nightmare"
config/description="Israeli hospital horror. Biggy is coming."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/icon.png"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[input]

; ═══════════════════════════════════
;  KEYBINDINGS  —  Best for PC FPS horror
;  Research: WASD movement is universal standard
;  Shift = sprint (left pinky, natural)
;  E = interact (index finger, close to WASD)
;  F = flashlight (middle finger column)
;  Q = look behind (left of W, instant access)
;  C = crouch (stealth — RE9 Grace mechanic)
;  Space = reserved / jump
;  Escape = pause / menu
; ═══════════════════════════════════

